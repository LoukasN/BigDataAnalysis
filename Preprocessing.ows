		<properties node_id="28" format="literal">{'auto_commit': True, 'color_by_class': True, 'controlAreaVisible': True, 'savedWidgetGeometry': b'\x01\xd9\xd0\xcb\x00\x03\x00\x00\x00\x00\x01\xc0\x00\x00\x00\x88\x00\x00\x05\xc1\x00\x00\x03\x9f\x00\x00\x01\xc1\x00\x00\x00\xa7\x00\x00\x05\xc0\x00\x00\x03\x9e\x00\x00\x00\x00\x00\x00\x00\x00\x07\x80\x00\x00\x01\xc1\x00\x00\x00\xa7\x00\x00\x05\xc0\x00\x00\x03\x9e', 'select_rows': True, 'show_attribute_labels': True, 'show_distributions': False, 'stored_selection': {'rows': [], 'columns': []}, 'stored_sort': [], '__version__': 1}</properties>
		<properties node_id="29" format="literal">{'controlAreaVisible': True, 'currentScriptIndex': 0, 'savedWidgetGeometry': b'\x01\xd9\xd0\xcb\x00\x03\x00\x00\x00\x00\x01J\x00\x00\x00\\\x00\x00\x08\xc9\x00\x00\x04\x93\x00\x00\x01J\x00\x00\x00\\\x00\x00\x05\x03\x00\x00\x04b\x00\x00\x00\x00\x02\x04\x00\x00\x07\x80\x00\x00\x01J\x00\x00\x00\\\x00\x00\x08\xc9\x00\x00\x04\x93', 'scriptLibrary': [{'name': 'Table from numpy', 'script': 'from Orange.data.pandas_compat import table_to_frame, table_from_frame\nimport pandas as pd\n\n# INPUT:  movie.csv (movieId, title, genres)\n# JOB:    find duplicate titles, build {old_movieId -&gt; canonical_movieId}.\n#         Canonical = smallest movieId among a title\'s duplicates.\n# OUTPUT: out_object -&gt; mapping dict (feeds the remap script via Object channel)\n#         out_data   -&gt; same mapping as a table (inspection only, optional)\n\ndf = table_to_frame(in_data, include_metas=True)\n\nid_mapping = {}\ndupes = df[df.duplicated(subset=[\'title\'], keep=False)]\nfor title, group in dupes.groupby(\'title\'):\n    canonical_id = group[\'movieId\'].min()\n    for old_id in group[\'movieId\']:\n        if old_id != canonical_id:\n            id_mapping[int(old_id)] = int(canonical_id)\n\nprint(f"Duplicate-title movies remapped: {len(id_mapping)}")\nprint(f"ID mappings: {id_mapping}")\n\nout_object = id_mapping   # primary: the dict, over the Object channel\n\nout_data = table_from_frame(   # secondary: eyeball it in a Data Table\n    pd.DataFrame({\'old_movieId\': list(id_mapping.keys()),\n                  \'new_movieId\': list(id_mapping.values())})\n)', 'filename': None}], 'scriptText': 'from Orange.data.pandas_compat import table_to_frame, table_from_frame\nimport pandas as pd\n\ndf = table_to_frame(in_data, include_metas=True)\n\nidMapping = {}\ndupes = df[df.duplicated(subset=[\'title\'], keep=False)]\nfor title, group in dupes.groupby(\'title\'):\n    keptId = group[\'movieId\'].min()\n    for oldId in group[\'movieId\']:\n        if oldId != keptId:\n            idMapping[int(oldId)] = int(keptId)\n\nprint(f"Duplicate-title movies: {len(idMapping)}")\nprint(f"ID mappings: {idMapping}")\n\nout_object = idMapping\n\nout_data = table_from_frame(\n    pd.DataFrame({\'oldId\': list(idMapping.keys()),\n                  \'newId\': list(idMapping.values())})\n)', 'splitterState': b'\x00\x00\x00\xff\x00\x00\x00\x01\x00\x00\x00\x02\x00\x00\x00\xac\x00\x00\x00h\x01\xff\xff\xff\xff\x01\x00\x00\x00\x02\x00', 'vimModeEnabled': True, '__version__': 2}</properties>

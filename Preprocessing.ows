		<properties node_id="23" format="literal">{'controlAreaVisible': True, 'currentScriptIndex': 0, 'savedWidgetGeometry': b'\x01\xd9\xd0\xcb\x00\x03\x00\x00\x00\x00\x01@\x00\x00\x00\x8b\x00\x00\x04\xf9\x00\x00\x04\x91\x00\x00\x01@\x00\x00\x00\x8b\x00\x00\x04\xf9\x00\x00\x04\x91\x00\x00\x00\x00\x00\x00\x00\x00\x07\x80\x00\x00\x01@\x00\x00\x00\x8b\x00\x00\x04\xf9\x00\x00\x04\x91', 'scriptLibrary': [{'name': 'Table from numpy', 'script': "from Orange.data.pandas_compat import table_to_frame, table_from_frame\nimport re\n\ndf = table_to_frame(in_data, include_metas=True)\n\ndef extractYear(title):\n    matches = re.findall(r'\\((\\d{4})\\)', str(title))\n    return int(matches[-1]) if matches else None\n\ndf['release_year'] = df['title'].apply(extractYear)\n\nout_data = table_from_frame(df)", 'filename': None}], 'scriptText': "from Orange.data.pandas_compat import table_to_frame, table_from_frame\nimport re\n\ndf = table_to_frame(in_data, include_metas=True)\n\ndef extractYear(title):\n    matches = re.findall(r'\\((\\d{4})\\)', str(title))\n    return int(matches[-1]) if matches else None\n\ndf['release_year'] = df['title'].apply(extractYear)\n\nout_data = table_from_frame(df)", 'splitterState': b'\x00\x00\x00\xff\x00\x00\x00\x01\x00\x00\x00\x02\x00\x00\x00\xac\x00\x00\x00h\x01\xff\xff\xff\xff\x01\x00\x00\x00\x02\x00', 'vimModeEnabled': False, '__version__': 2}</properties>
		<properties node_id="24" format="literal">{'controlAreaVisible': True, 'currentScriptIndex': 0, 'savedWidgetGeometry': b'\x01\xd9\xd0\xcb\x00\x03\x00\x00\x00\x00\x01J\x00\x00\x00\\\x00\x00\x05\x03\x00\x00\x04b\x00\x00\x01J\x00\x00\x00\\\x00\x00\x05\x03\x00\x00\x04b\x00\x00\x00\x00\x00\x00\x00\x00\x07\x80\x00\x00\x01J\x00\x00\x00\\\x00\x00\x05\x03\x00\x00\x04b', 'scriptLibrary': [{'name': 'Table from numpy', 'script': "from Orange.data.pandas_compat import table_to_frame, table_from_frame\n\ndf = table_to_frame(in_data, include_metas=True)\n\ndef countGenres(genre):\n    return 0 if genre == '(no genres listed)' else len(str(genre).split('|'))\n\ndf['genre_count'] = df['genres'].apply(countGenres)\n\nout_data = table_from_frame(df)", 'filename': None}], 'scriptText': "from Orange.data.pandas_compat import table_to_frame, table_from_frame\n\ndf = table_to_frame(in_data, include_metas=True)\n\ndef countGenres(genre):\n    return 0 if genre == '(no genres listed)' else len(str(genre).split('|'))\n\ndf['genre_count'] = df['genres'].apply(countGenres)\n\nout_data = table_from_frame(df)", 'splitterState': b'\x00\x00\x00\xff\x00\x00\x00\x01\x00\x00\x00\x02\x00\x00\x00\xac\x00\x00\x00h\x01\xff\xff\xff\xff\x01\x00\x00\x00\x02\x00', 'vimModeEnabled': False, '__version__': 2}</properties>
		<properties node_id="25" format="literal">{'controlAreaVisible': True, 'currentScriptIndex': 0, 'savedWidgetGeometry': b'\x01\xd9\xd0\xcb\x00\x03\x00\x00\x00\x00\x01J\x00\x00\x00\\\x00\x00\x05\x03\x00\x00\x04b\x00\x00\x01J\x00\x00\x00\\\x00\x00\x05\x03\x00\x00\x04b\x00\x00\x00\x00\x00\x00\x00\x00\x07\x80\x00\x00\x01J\x00\x00\x00\\\x00\x00\x05\x03\x00\x00\x04b', 'scriptLibrary': [{'name': 'Table from numpy', 'script': 'from Orange.data.pandas_compat import table_to_frame\n\ndf = table_to_frame(in_data, include_metas=True)\n\nprint(f"Movies (unfiltered): {len(df)}")\nprint(f"release_year missing: {df[\'release_year\'].isna().sum()}")\nprint(f"rating_std missing: {df[\'rating_std\'].isna().sum()}")\nprint(f"no-genre movies: {(df[\'genre_count\'] == 0).sum()}")\n\nout_data = in_data', 'filename': None}], 'scriptText': 'from Orange.data.pandas_compat import table_to_frame\n\ndf = table_to_frame(in_data, include_metas=True)\n\nprint(f"Movies (unfiltered): {len(df)}")\nprint(f"release_year missing: {df[\'release_year\'].isna().sum()}")\nprint(f"rating_std missing: {df[\'rating_std\'].isna().sum()}")\nprint(f"no-genre movies: {(df[\'genre_count\'] == 0).sum()}")\n\nout_data = in_data', 'splitterState': b'\x00\x00\x00\xff\x00\x00\x00\x01\x00\x00\x00\x02\x00\x00\x00\xac\x00\x00\x00h\x01\xff\xff\xff\xff\x01\x00\x00\x00\x02\x00', 'vimModeEnabled': False, '__version__': 2}</properties>

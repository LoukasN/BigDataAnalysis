		<properties node_id="5" format="literal">{'controlAreaVisible': True, 'currentScriptIndex': 0, 'savedWidgetGeometry': b'\x01\xd9\xd0\xcb\x00\x03\x00\x00\x00\x00\x01\xfb\x00\x00\x01w\x00\x00\x06\xb5\x00\x00\x03\xed\x00\x00\x01\xfc\x00\x00\x01\x96\x00\x00\x06\xb4\x00\x00\x03\xec\x00\x00\x00\x00\x00\x00\x00\x00\x07\x80\x00\x00\x01\xfc\x00\x00\x01\x96\x00\x00\x06\xb4\x00\x00\x03\xec', 'scriptLibrary': [{'name': 'Table from numpy', 'script': 'from Orange.data.pandas_compat import table_to_frame, table_from_frame\n\n# INPUT:  movie.csv (movieId, title, genres)\n# JOB:    collapse duplicate titles into one row, unioning their genres.\n# OUTPUT: clean movie table, one row per unique title.\n\ndf = table_to_frame(in_data, include_metas=True)\n\ndef merge_genres(genres_series):\n    all_genres = set()\n    for g in genres_series:\n        for genre in str(g).split(\'|\'):\n            all_genres.add(genre.strip())\n    return \'|\'.join(sorted(all_genres))\n\ndf_clean = df.groupby(\'title\', as_index=False).agg(\n    movieId=(\'movieId\', \'min\'),          # smallest id = canonical\n    genres=(\'genres\', merge_genres),\n)\n\nprint(f"Πριν: {len(df)} γραμμές")\nprint(f"Μετά: {len(df_clean)} γραμμές")\n\nout_data = table_from_frame(df_clean)', 'filename': None}], 'scriptText': 'from Orange.data.pandas_compat import table_to_frame, table_from_frame\n\n# INPUT:  movie.csv (movieId, title, genres)\n# JOB:    collapse duplicate titles into one row, unioning their genres.\n# OUTPUT: clean movie table, one row per unique title.\n\ndf = table_to_frame(in_data, include_metas=True)\n\ndef merge_genres(genres_series):\n    all_genres = set()\n    for g in genres_series:\n        for genre in str(g).split(\'|\'):\n            all_genres.add(genre.strip())\n    return \'|\'.join(sorted(all_genres))\n\ndf_clean = df.groupby(\'title\', as_index=False).agg(\n    movieId=(\'movieId\', \'min\'),          # smallest id = canonical\n    genres=(\'genres\', merge_genres),\n)\n\nprint(f"Πριν: {len(df)} γραμμές")\nprint(f"Μετά: {len(df_clean)} γραμμές")\n\nout_data = table_from_frame(df_clean)', 'splitterState': b'\x00\x00\x00\xff\x00\x00\x00\x01\x00\x00\x00\x02\x00\x00\x00\xa5\x00\x00\x00f\x01\xff\xff\xff\xff\x01\x00\x00\x00\x02\x00', 'vimModeEnabled': False, '__version__': 2}</properties>

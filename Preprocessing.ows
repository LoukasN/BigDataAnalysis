		<properties node_id="1" format="literal">{'controlAreaVisible': False, 'currentScriptIndex': 0, 'savedWidgetGeometry': b'\x01\xd9\xd0\xcb\x00\x03\x00\x00\x00\x00\x01\xa9\x00\x00\x00Y\x00\x00\t(\x00\x00\x04\x90\x00\x00\x01\xa9\x00\x00\x00Y\x00\x00\t(\x00\x00\x04\x90\x00\x00\x00\x00\x02\x04\x00\x00\x07\x80\x00\x00\x01\xa9\x00\x00\x00Y\x00\x00\t(\x00\x00\x04\x90', 'scriptLibrary': [{'name': 'Table from numpy', 'script': 'from Orange.data.pandas_compat import table_to_frame\n\ndf = table_to_frame(in_data, include_metas=True)\n\nprint(f"=== Duplicate Analysis ===")\nprint(f"All movies: {len(df)}")\nprint(f"Columns: {df.columns.tolist()}")\n\nfor col in df.columns:\n    unique = df[col].nunique()\n    dupes = len(df) - unique\n    dupePercent = (dupes / len(df)) * 100\n    print(f"\\n[{col}]")\n    print(f"  Unique: {unique}")\n    print(f"  Duplicates: {dupes} ({dupePercent:.2f}%)")\n    # Shows up to 100 duplicates\n    if dupes &gt; 0 and dupes &lt; 100:\n        print(f"  Duplicate values:")\n        dupes = df[col][df[col].duplicated(keep=False)].unique()\n        for v in dupes:\n            print(f"    {v}")', 'filename': None}], 'scriptText': 'from Orange.data.pandas_compat import table_to_frame\n\ndf = table_to_frame(in_data, include_metas=True)\n\nprint(f"=== Duplicate Analysis ===")\nprint(f"All movies: {len(df)}")\nprint(f"Columns: {df.columns.tolist()}")\n\nfor col in df.columns:\n    unique = df[col].nunique()\n    dupes = len(df) - unique\n    dupePercent = (dupes / len(df)) * 100\n    print(f"\\n[{col}]")\n    print(f"  Unique: {unique}")\n    print(f"  Duplicates: {dupes} ({dupePercent:.2f}%)")\n    # Shows up to 100 duplicates\n    if dupes &gt; 0 and dupes &lt; 100:\n        print(f"  Duplicate values:")\n        dupes = df[col][df[col].duplicated(keep=False)].unique()\n        for v in dupes:\n            print(f"    {v}")', 'splitterState': b'\x00\x00\x00\xff\x00\x00\x00\x01\x00\x00\x00\x02\x00\x00\x00\xac\x00\x00\x00h\x01\xff\xff\xff\xff\x01\x00\x0
		<properties node_id="13" format="literal">{'auto_commit': True, 'color_by_class': True, 'controlAreaVisible': True, 'savedWidgetGeometry': b'\x01\xd9\xd0\xcb\x00\x03\x00\x00\x00\x00\x00\xe6\x00\x00\x00\xd2\x00\x00\x04\xed\x00\x00\x03\xe9\x00\x00\x00\xe7\x00\x00\x00\xf1\x00\x00\x04\xec\x00\x00\x03\xe8\x00\x00\x00\x00\x00\x00\x00\x00\x07\x80\x00\x00\x00\xe7\x00\x00\x00\xf1\x00\x00\x04\xec\x00\x00\x03\xe8', 'select_rows': True, 'show_attribute_labels': True, 'show_distributions': False, 'stored_selection': {'rows': [], 'columns': []}, 'stored_sort': [('movieId', 1)], '__version__': 1}</properties>
		<properties node_id="14" format="literal">{'controlAreaVisible': True, 'currentScriptIndex': 0, 'savedWidgetGeometry': b'\x01\xd9\xd0\xcb\x00\x03\x00\x00\x00\x00\x00\x87\x00\x00\x00:\x00\x00\x05\xf4\x00\x00\x03\xb2\x00\x00\x00\x88\x00\x00\x00Y\x00\x00\x05\xf3\x00\x00\x03\xb1\x00\x00\x00\x00\x00\x00\x00\x00\x07\x80\x00\x00\x00\x88\x00\x00\x00Y\x00\x00\x05\xf3\x00\x00\x03\xb1', 'scriptLibrary': [{'name': 'Table from numpy', 'script': 'from Orange.data.pandas_compat import table_to_frame, table_from_frame\n\n# INPUT:  in_data   -&gt; rating.csv (userId, movieId, rating, timestamp)\n#         in_object -&gt; {old_movieId -&gt; canonical_movieId} from script 2\n# JOB:    rewrite duplicate movieIds to canonical. No hardcoded dict.\n# OUTPUT: rating table with remapped movieId.\n\nif in_object is None:                       # guard: mapping must be connected\n    raise ValueError("No mapping on the Object input — connect "\n                     "\'Build movieId mapping\' to this widget\'s Object input.")\n\nid_mapping = in_object\ndf = table_to_frame(in_data, include_metas=True)\n\nprint(f"Πριν mapping: {df[\'movieId\'].nunique()} unique movieIds")\ndf[\'movieId\'] = df[\'movieId\'].replace(id_mapping)\nprint(f"Μετά mapping: {df[\'movieId\'].nunique()} unique movieIds")\n\nout_data = table_from_frame(df)', 'filename': None}], 'scriptText': 'from Orange.data.pandas_compat import table_to_frame, table_from_frame\n\n# INPUT:  in_data   -&gt; rating.csv (userId, movieId, rating, timestamp)\n#         in_object -&gt; {old_movieId -&gt; canonical_movieId} from script 2\n# JOB:    rewrite duplicate movieIds to canonical. No hardcoded dict.\n# OUTPUT: rating table with remapped movieId.\n\nif in_object is None:                       # guard: mapping must be connected\n    raise ValueError("No mapping on the Object input — connect "\n                     "\'Build movieId mapping\' to this widget\'s Object input.")\n\nid_mapping = in_object\ndf = table_to_frame(in_data, include_metas=True)\n\nprint(f"Πριν mapping: {df[\'movieId\'].nunique()} unique movieIds")\ndf[\'movieId\'] = df[\'movieId\'].replace(id_mapping)\nprint(f"Μετά mapping: {df[\'movieId\'].nunique()} unique movieIds")\n\nout_data = table_from_frame(df)', 'splitterState': b'\x00\x00\x00\xff\x00\x00\x00\x01\x00\x00\x00\x02\x00\x00\x00\xa5\x00\x00\x00f\x01\xff\xff\xff\xff\x01\x00\x00\x00\x02\x00', 'vimModeEnabled': False, '__version__': 2}</properties>

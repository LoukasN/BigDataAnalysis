		<properties node_id="18" format="literal">{'controlAreaVisible': True, 'currentScriptIndex': 0, 'savedWidgetGeometry': b'\x01\xd9\xd0\xcb\x00\x03\x00\x00\x00\x00\x02/\x00\x00\x00\xb9\x00\x00\x05P\x00\x00\x030\x00\x00\x020\x00\x00\x00\xd8\x00\x00\x05O\x00\x00\x03/\x00\x00\x00\x00\x00\x00\x00\x00\x07\x80\x00\x00\x020\x00\x00\x00\xd8\x00\x00\x05O\x00\x00\x03/', 'scriptLibrary': [{'name': 'Table from numpy', 'script': '# Diagnostic only — list unique genre tokens. Delete after reading.\nimport Orange\n\ngenres_var = in_data.domain["genres"]\ncol_idx = in_data.domain.index(genres_var)\n\ntokens = set()\nfor row in in_data:\n    val = str(row[genres_var])\n    if val and val != "?":            # skip Orange\'s missing marker\n        for g in val.split("|"):\n            tokens.add(g.strip())\n\nprint("Unique genre tokens:", len(tokens))\nfor t in sorted(tokens):\n    print(" -", t)\n\nout_data = in_data  # pass-through, changes nothing', 'filename': None}], 'scriptText': '# Diagnostic only — list unique genre tokens. Delete after reading.\nimport Orange\n\ngenres_var = in_data.domain["genres"]\ncol_idx = in_data.domain.index(genres_var)\n\ntokens = set()\nfor row in in_data:\n    val = str(row[genres_var])\n    if val and val != "?":            # skip Orange\'s missing marker\n        for g in val.split("|"):\n            tokens.add(g.strip())\n\nprint("Unique genre tokens:", len(tokens))\nfor t in sorted(tokens):\n    print(" -", t)\n\nout_data = in_data  # pass-through, changes nothing', 'splitterState': b'\x00\x00\x00\xff\x00\x00\x00\x01\x00\x00\x00\x02\x00\x00\x00\x9f\x00\x00\x00`\x01\xff\xff\xff\xff\x01\x00\x00\x00\x02\x00', 'vimModeEnabled': False, '__version__': 2}</properties>
		<properties node_id="19" format="literal">{'controlAreaVisible': True, 'currentScriptIndex': 0, 'savedWidgetGeometry': b'\x01\xd9\xd0\xcb\x00\x03\x00\x00\xff\xff\xff\xff\xff\xff\xff\xf8\x00\x00\x07\x80\x00\x00\x04\x08\x00\x00\x00\x00\x00\x00\x00\x17\x00\x00\x07\x7f\x00\x00\x04\x07\x00\x00\x00\x00\x02\x00\x00\x00\x07\x80\x00\x00\x00\x00\x00\x00\x00\x17\x00\x00\x07\x7f\x00\x00\x04\x07', 'scriptLibrary': [{'name': 'Table from numpy', 'script': '# One-hot encode the |-delimited genres column.\n# Dynamic token derivation, no hardcoded list.\n# Column order: no_genre first, then the 19 genre_* columns alphabetically.\n# A movie is either in one-or-more real genres, or flagged no_genre — never both.\n# NOTE: `genres` is ALREADY a meta — do not re-add it.\nimport numpy as np\nimport Orange\nfrom Orange.data import Domain, ContinuousVariable\n\nPLACEHOLDER = "(no genres listed)"   # TODO: confirm token if dataset ever changes\ngenres_var = in_data.domain["genres"]\n\n# Real genre tokens for a row; empty set means the movie has no genre.\ndef real_tokens(val):\n    if not val or val == "?":\n        return set()\n    return {g.strip() for g in val.split("|")\n            if g.strip() and g.strip() != PLACEHOLDER}\n\n# Collect the genre vocabulary dynamically (sorted for stable column order).\nvocabulary = set()\nfor row in in_data:\n    vocabulary |= real_tokens(str(row[genres_var]))\ngenre_list = sorted(vocabulary)\n\n# Column layout: no_genre first, then one column per real genre.\ncolumns = ["no_genre"] + ["genre_" + g for g in genre_list]\nnew_vars = [ContinuousVariable(name) for name in columns]\n\n# Fill the binary matrix in that same order.\nonehot = np.zeros((len(in_data), len(columns)), dtype=float)\nfor i, row in enumerate(in_data):\n    present = real_tokens(str(row[genres_var]))\n    if present:\n        for j, g in enumerate(genre_list):\n            onehot[i, j + 1] = 1.0 if g in present else 0.0   # +1: skip no_genre\n    else:\n        onehot[i, 0] = 1.0                                    # no_genre column\n\n# Append the new columns; leave class and metas untouched.\nold = in_data.domain\nnew_domain = Domain(list(old.attributes) + new_vars, old.class_vars, old.metas)\nout_data = in_data.transform(new_domain)\nout_data.X[:, -len(columns):] = onehot\n\nprint("Genre columns added:", len(columns), "(no_genre + ", len(genre_list), "genres)")\nprint("Order:", ", ".join(columns))\nprint("No-genre movies flagged:", int(onehot[:, 0].sum()))', 'filename': None}], 'scriptText': '# One-hot encode the |-delimited genres column.\n# Dynamic token derivation, no hardcoded list.\n# Column order: no_genre first, then the 19 genre_* columns alphabetically.\n# A movie is either in one-or-more real genres, or flagged no_genre — never both.\n# NOTE: `genres` is ALREADY a meta — do not re-add it.\nimport numpy as np\nimport Orange\nfrom Orange.data import Domain, ContinuousVariable\n\nPLACEHOLDER = "(no genres listed)"   # TODO: confirm token if dataset ever changes\ngenres_var = in_data.domain["genres"]\n\n# Real genre tokens for a row; empty set means the movie has no genre.\ndef real_tokens(val):\n    if not val or val == "?":\n        return set()\n    return {g.strip() for g in val.split("|")\n            if g.strip() and g.strip() != PLACEHOLDER}\n\n# Collect the genre vocabulary dynamically (sorted for stable column order).\nvocabulary = set()\nfor row in in_data:\n    vocabulary |= real_tokens(str(row[genres_var]))\ngenre_list = sorted(vocabulary)\n\n# Column layout: no_genre first, then one column per real genre.\ncolumns = ["no_genre"] + ["genre_" + g for g in genre_list]\nnew_vars = [ContinuousVariable(name) for name in columns]\n\n# Fill the binary matrix in that same order.\nonehot = np.zeros((len(in_data), len(columns)), dtype=float)\nfor i, row in enumerate(in_data):\n    present = real_tokens(str(row[genres_var]))\n    if present:\n        for j, g in enumerate(genre_list):\n            onehot[i, j + 1] = 1.0 if g in present else 0.0   # +1: skip no_genre\n    else:\n        onehot[i, 0] = 1.0                                    # no_genre column\n\n# Append the new columns; leave class and metas untouched.\nold = in_data.domain\nnew_domain = Domain(list(old.attributes) + new_vars, old.class_vars, old.metas)\nout_data = in_data.transform(new_domain)\nout_data.X[:, -len(columns):] = onehot\n\nprint("Genre columns added:", len(columns), "(no_genre + ", len(genre_list), "genres)")\nprint("Order:", ", ".join(columns))\nprint("No-genre movies flagged:", int(onehot[:, 0].sum()))', 'splitterState': b'\x00\x00\x00\xff\x00\x00\x00\x01\x00\x00\x00\x02\x00\x00\x00\x9f\x00\x00\x00`\x01\xff\xff\xff\xff\x01\x00\x00\x00\x02\x00', 'vimModeEnabled': False, '__version__': 2}</properties>
		<properties node_id="20" format="literal">{'auto_commit': True, 'color_by_class': True, 'controlAreaVisible': True, 'savedWidgetGeometry': b'\x01\xd9\xd0\xcb\x00\x03\x00\x00\xff\xff\xffA\x00\x00\x00\x7f\x00\x00\x06\xce\x00\x00\x04\x8d\xff\xff\xffI\x00\x00\x00\x9e\x00\x00\x06\xc6\x00\x00\x04\x85\x00\x00\x00\x00\x00\x00\x00\x00\x07\x80\xff\xff\xffI\x00\x00\x00\x9e\x00\x00\x06\xc6\x00\x00\x04\x85', 'select_rows': True, 'show_attribute_labels': True, 'show_distributions': False, 'stored_selection': {'rows': [], 'columns': []}, 'stored_sort': [], '__version__': 1}</properties>
		<properties node_id="21" format="literal">{'auto_commit': True, 'color_by_class': True, 'controlAreaVisible': True, 'savedWidgetGeometry': b'\x01\xd9\xd0\xcb\x00\x03\x00\x00\x00\x00\x02/\x00\x00\x00\xeb\x00\x00\x05P\x00\x00\x02\xfe\x00\x00\x020\x00\x00\x01\n\x00\x00\x05O\x00\x00\x02\xfd\x00\x00\x00\x00\x00\x00\x00\x00\x07\x80\x00\x00\x020\x00\x00\x01\n\x00\x00\x05O\x00\x00\x02\xfd', 'select_rows': True, 'show_attribute_labels': True, 'show_distributions': False, 'stored_selection': {'rows': [], 'columns': []}, 'stored_sort': [], '__version__': 1}</properties>
		<properties node_id="22" format="literal">{'controlAreaVisible': True, 'currentScriptIndex': 0, 'savedWidgetGeometry': b'\x01\xd9\xd0\xcb\x00\x03\x00\x00\x00\x00\x01I\x00\x00\x00=\x00\x00\x06\xb6\x00\x00\x03\xb5\x00\x00\x01J\x00\x00\x00\\\x00\x00\x06\xb5\x00\x00\x03\xb4\x00\x00\x00\x00\x00\x00\x00\x00\x07\x80\x00\x00\x01J\x00\x00\x00\\\x00\x00\x06\xb5\x00\x00\x03\xb4', 'scriptLibrary': [{'name': 'Table from numpy', 'script': "from Orange.data.pandas_compat import table_to_frame, table_from_frame\n\ndf = table_to_frame(in_data, include_metas=True)\n\n# Collapse 20M rating rows → one row per movie. No native Orange equivalent.\n# Aggregates use the FULL data (before any filter) so count/std are unbiased.\nagg = df.groupby('movieId').agg(\n    avg_movie_rating=('rating', 'mean'),    # quality signal → defines target\n    rating_count=('rating', 'count'),       # popularity / reliability\n    rating_std=('rating', 'std'),           # consensus vs controversy\n    title=('title', 'first'),\n    genres=('genres', 'first'),\n).reset_index()\n\nout_data = table_from_frame(agg)", 'filename': None}], 'scriptText': "from Orange.data.pandas_compat import table_to_frame, table_from_frame\n\ndf = table_to_frame(in_data, include_metas=True)\n\n# Collapse 20M rating rows → one row per movie. No native Orange equivalent.\n# Aggregates use the FULL data (before any filter) so count/std are unbiased.\nagg = df.groupby('movieId').agg(\n    avg_movie_rating=('rating', 'mean'),    # quality signal → defines target\n    rating_count=('rating', 'count'),       # popularity / reliability\n    rating_std=('rating', 'std'),           # consensus vs controversy\n    title=('title', 'first'),\n    genres=('genres', 'first'),\n).reset_index()\n\nout_data = table_from_frame(agg)", 'splitterState': b'\x00\x00\x00\xff\x00\x00\x00\x01\x00\x00\x00\x02\x00\x00\x00\xa5\x00\x00\x00f\x01\xff\xff\xff\xff\x01\x00\x00\x00\x02\x00', 'vimModeEnabled': False, '__version__': 2}</properties>
		<properties node_id="23" format="literal">{'controlAreaVisible': True, 'currentScriptIndex': 0, 'savedWidgetGeometry': b'\x01\xd9\xd0\xcb\x00\x03\x00\x00\x00\x00\x01?\x00\x00\x00l\x00\x00\x06\xac\x00\x00\x03\xe4\x00\x00\x01@\x00\x00\x00\x8b\x00\x00\x06\xab\x00\x00\x03\xe3\x00\x00\x00\x00\x00\x00\x00\x00\x07\x80\x00\x00\x01@\x00\x00\x00\x8b\x00\x00\x06\xab\x00\x00\x03\xe3', 'scriptLibrary': [{'name': 'Table from numpy', 'script': 'from Orange.data.pandas_compat import table_to_frame, table_from_frame\nimport re\n\ndf = table_to_frame(in_data, include_metas=True)\n\n# Extract release year from titles like "Toy Story (1995)".\n# Uses the LAST parenthesized 4-digit group (handles other parens in titles).\ndef extract_year(title):\n    matches = re.findall(r\'\\((\\d{4})\\)\', str(title))\n    return int(matches[-1]) if matches else None\n\ndf[\'release_year\'] = df[\'title\'].apply(extract_year)\n\nout_data = table_from_frame(df)', 'filename': None}], 'scriptText': 'from Orange.data.pandas_compat import table_to_frame, table_from_frame\nimport re\n\ndf = table_to_frame(in_data, include_metas=True)\n\n# Extract release year from titles like "Toy Story (1995)".\n# Uses the LAST parenthesized 4-digit group (handles other parens in titles).\ndef extract_year(title):\n    matches = re.findall(r\'\\((\\d{4})\\)\', str(title))\n    return int(matches[-1]) if matches else None\n\ndf[\'release_year\'] = df[\'title\'].apply(extract_year)\n\nout_data = table_from_frame(df)', 'splitterState': b'\x00\x00\x00\xff\x00\x00\x00\x01\x00\x00\x00\x02\x00\x00\x00\xa5\x00\x00\x00f\x01\xff\xff\xff\xff\x01\x00\x00\x00\x02\x00', 'vimModeEnabled': False, '__version__': 2}</properties>
		<properties node_id="24" format="literal">{'controlAreaVisible': True, 'currentScriptIndex': 0, 'savedWidgetGeometry': b'\x01\xd9\xd0\xcb\x00\x03\x00\x00\x00\x00\x01I\x00\x00\x00=\x00\x00\x06\xb6\x00\x00\x03\xb5\x00\x00\x01J\x00\x00\x00\\\x00\x00\x06\xb5\x00\x00\x03\xb4\x00\x00\x00\x00\x00\x00\x00\x00\x07\x80\x00\x00\x01J\x00\x00\x00\\\x00\x00\x06\xb5\x00\x00\x03\xb4', 'scriptLibrary': [{'name': 'Table from numpy', 'script': 'from Orange.data.pandas_compat import table_to_frame, table_from_frame\n\ndf = table_to_frame(in_data, include_metas=True)\n\n# Count genres. The "(no genres listed)" placeholder → 0 (a true zero, not missing).\ndef count_genres(g):\n    return 0 if g == \'(no genres listed)\' else len(str(g).split(\'|\'))\n\ndf[\'genre_count\'] = df[\'genres\'].apply(count_genres)\n\nout_data = table_from_frame(df)', 'filename': None}], 'scriptText': 'from Orange.data.pandas_compat import table_to_frame, table_from_frame\n\ndf = table_to_frame(in_data, include_metas=True)\n\n# Count genres. The "(no genres listed)" placeholder → 0 (a true zero, not missing).\ndef count_genres(g):\n    return 0 if g == \'(no genres listed)\' else len(str(g).split(\'|\'))\n\ndf[\'genre_count\'] = df[\'genres\'].apply(count_genres)\n\nout_data = table_from_frame(df)', 'splitterState': b'\x00\x00\x00\xff\x00\x00\x00\x01\x00\x00\x00\x02\x00\x00\x00\xa5\x00\x00\x00f\x01\xff\xff\xff\xff\x01\x00\x00\x00\x02\x00', 'vimModeEnabled': False, '__version__': 2}</properties>
		<properties node_id="25" format="literal">{'controlAreaVisible': True, 'currentScriptIndex': 0, 'savedWidgetGeometry': b'\x01\xd9\xd0\xcb\x00\x03\x00\x00\x00\x00\x01I\x00\x00\x00=\x00\x00\x06\xb6\x00\x00\x03\xb5\x00\x00\x01J\x00\x00\x00\\\x00\x00\x06\xb5\x00\x00\x03\xb4\x00\x00\x00\x00\x00\x00\x00\x00\x07\x80\x00\x00\x01J\x00\x00\x00\\\x00\x00\x06\xb5\x00\x00\x03\xb4', 'scriptLibrary': [{'name': 'Table from numpy', 'script': 'from Orange.data.pandas_compat import table_to_frame\n\ndf = table_to_frame(in_data, include_metas=True)\n\n# Read-only audit for the report. Does not modify the data.\nprint(f"Movies (unfiltered): {len(df)}")\nprint(f"release_year missing: {df[\'release_year\'].isna().sum()}")\nprint(f"rating_std missing: {df[\'rating_std\'].isna().sum()}")\nprint(f"no-genre movies: {(df[\'genre_count\'] == 0).sum()}")\n\nout_data = in_data   # pass-through, unchanged', 'filename': None}], 'scriptText': 'from Orange.data.pandas_compat import table_to_frame\n\ndf = table_to_frame(in_data, include_metas=True)\n\n# Read-only audit for the report. Does not modify the data.\nprint(f"Movies (unfiltered): {len(df)}")\nprint(f"release_year missing: {df[\'release_year\'].isna().sum()}")\nprint(f"rating_std missing: {df[\'rating_std\'].isna().sum()}")\nprint(f"no-genre movies: {(df[\'genre_count\'] == 0).sum()}")\n\nout_data = in_data   # pass-through, unchanged', 'splitterState': b'\x00\x00\x00\xff\x00\x00\x00\x01\x00\x00\x00\x02\x00\x00\x00\xa5\x00\x00\x00f\x01\xff\xff\xff\xff\x01\x00\x00\x00\x02\x00', 'vimModeEnabled': False, '__version__': 2}</properties>

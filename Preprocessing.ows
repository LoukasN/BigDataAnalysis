		<properties node_id="18" format="literal">{'controlAreaVisible': True, 'currentScriptIndex': 0, 'savedWidgetGeometry': b'\x01\xd9\xd0\xcb\x00\x03\x00\x00\x00\x00\x020\x00\x00\x00\xd8\x00\x00\x05\xe9\x00\x00\x04\xde\x00\x00\x020\x00\x00\x00\xd8\x00\x00\x05\xe9\x00\x00\x04\xde\x00\x00\x00\x00\x00\x00\x00\x00\x07\x80\x00\x00\x020\x00\x00\x00\xd8\x00\x00\x05\xe9\x00\x00\x04\xde', 'scriptLibrary': [{'name': 'Table from numpy', 'script': 'import Orange\n\ngenres_var = in_data.domain["genres"]\ncol_idx = in_data.domain.index(genres_var)\n\ntokens = set()\nfor row in in_data:\n    val = str(row[genres_var])\n    if val and val != "?":\n        for g in val.split("|"):\n            tokens.add(g.strip())\n\nprint("Unique genre tokens:", len(tokens))\nfor t in sorted(tokens):\n    print(" -", t)\n\nout_data = in_data', 'filename': None}], 'scriptText': 'import Orange\n\ngenres_var = in_data.domain["genres"]\ncol_idx = in_data.domain.index(genres_var)\n\ntokens = set()\nfor row in in_data:\n    val = str(row[genres_var])\n    if val and val != "?":\n        for g in val.split("|"):\n            tokens.add(g.strip())\n\nprint("Unique genre tokens:", len(tokens))\nfor t in sorted(tokens):\n    print(" -", t)\n\nout_data = in_data', 'splitterState': b'\x00\x00\x00\xff\x00\x00\x00\x01\x00\x00\x00\x02\x00\x00\x00\xac\x00\x00\x00h\x01\xff\xff\xff\xff\x01\x00\x00\x00\x02\x00', 'vimModeEnabled': False, '__version__': 2}</properties>
		<properties node_id="19" format="literal">{'controlAreaVisible': True, 'currentScriptIndex': 0, 'savedWidgetGeometry': b'\x01\xd9\xd0\xcb\x00\x03\x00\x00\x00\x00\x00\x00\x00\x00\x00\x17\x00\x00\x03\xb9\x00\x00\x04\x1d\x00\x00\x00\x00\x00\x00\x00\x17\x00\x00\x03\xb9\x00\x00\x04\x1d\x00\x00\x00\x00\x02\x00\x00\x00\x07\x80\x00\x00\x00\x00\x00\x00\x00\x17\x00\x00\x03\xb9\x00\x00\x04\x1d', 'scriptLibrary': [{'name': 'Table from numpy', 'script': 'import numpy as np\nimport Orange\nfrom Orange.data import Domain, ContinuousVariable\n\nPLACEHOLDER = "(no genres listed)"\ngenresVar = in_data.domain["genres"]\n\ndef realTokens(val):\n    if not val or val == "?":\n        return set()\n    return {genre.strip() for genre in val.split("|")\n            if genre.strip() and genre.strip() != "(no genres listed)"}\n\nvocabulary = set()\nfor row in in_data:\n    vocabulary |= real_tokens(str(row[genresVar]))\ngenreList = sorted(vocabulary)\n\ncolumns = ["no_genre"] + ["genre_" + genre for genre in genreList]\nnewVars = [ContinuousVariable(name) for name in columns]\n\nonehot = np.zeros((len(in_data), len(columns)), dtype=float)\nfor i, row in enumerate(in_data):\n    present = realTokens(str(row[genresVar]))\n    if present:\n        for j, genre in enumerate(genreList):\n            onehot[i, j + 1] = 1.0 if genre in present else 0.0\n    else:\n        onehot[i, 0] = 1.0\n\nold = in_data.domain\nnew_domain = Domain(list(old.attributes) + newVars, old.class_vars, old.metas)\nout_data = in_data.transform(new_domain)\nout_data.X[:, -len(columns):] = onehot\n\nprint("Genre columns added:", len(columns), "(no_genre + ", len(genre_list), "genres)")\nprint("Order:", ", ".join(columns))\nprint("No-genre movies flagged:", int(onehot[:, 0].sum()))', 'filename': None}], 'scriptText': 'import numpy as np\nimport Orange\nfrom Orange.data import Domain, ContinuousVariable\n\nPLACEHOLDER = "(no genres listed)"\ngenresVar = in_data.domain["genres"]\n\ndef realTokens(val):\n    if not val or val == "?":\n        return set()\n    return {genre.strip() for genre in val.split("|")\n            if genre.strip() and genre.strip() != "(no genres listed)"}\n\nvocabulary = set()\nfor row in in_data:\n    vocabulary |= real_tokens(str(row[genresVar]))\ngenreList = sorted(vocabulary)\n\ncolumns = ["no_genre"] + ["genre_" + genre for genre in genreList]\nnewVars = [ContinuousVariable(name) for name in columns]\n\nonehot = np.zeros((len(in_data), len(columns)), dtype=float)\nfor i, row in enumerate(in_data):\n    present = realTokens(str(row[genresVar]))\n    if present:\n        for j, genre in enumerate(genreList):\n            onehot[i, j + 1] = 1.0 if genre in present else 0.0\n    else:\n        onehot[i, 0] = 1.0\n\nold = in_data.domain\nnew_domain = Domain(list(old.attributes) + newVars, old.class_vars, old.metas)\nout_data = in_data.transform(new_domain)\nout_data.X[:, -len(columns):] = onehot\n\nprint("Genre columns added:", len(columns), "(no_genre + ", len(genre_list), "genres)")\nprint("Order:", ", ".join(columns))\nprint("No-genre movies flagged:", int(onehot[:, 0].sum()))', 'splitterState': b'\x00\x00\x00\xff\x00\x00\x00\x01\x00\x00\x00\x02\x00\x00\x00\xac\x00\x00\x00h\x01\xff\xff\xff\xff\x01\x00\x00\x00\x02\x00', 'vimModeEnabled': False, '__version__': 2}</properties>

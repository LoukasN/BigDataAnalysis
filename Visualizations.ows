		<properties node_id="5" format="literal">{'controlAreaVisible': True, 'currentScriptIndex': 0, 'savedWidgetGeometry': b'\x01\xd9\xd0\xcb\x00\x03\x00\x00\x00\x00\x02\x81\x00\x00\x00\x10\x00\x00\x07\x80\x00\x00\x05\x7f\x00\x00\x02\x82\x00\x00\x00/\x00\x00\x07\x7f\x00\x00\x05~\x00\x00\x00\x00\x00\x00\x00\x00\n\x00\x00\x00\x02\x82\x00\x00\x00/\x00\x00\x07\x7f\x00\x00\x05~', 'scriptLibrary': [{'name': 'Genre table', 'script': 'from Orange.data.pandas_compat import table_to_frame, table_from_frame\nimport pandas as pd\n\ndf = table_to_frame(in_data, include_metas=True)\n\ngcols = [c for c in df.columns if c.startswith("genre_") and c != "genre_count"]\nrows = []\nfor c in gcols:\n    m = df[c] == 1\n    rows.append({\n        "genre": c.replace("genre_", ""),\n        "n_movies": int(m.sum()),\n        "mean_avg_rating": round(df.loc[m, "avg_movie_rating"].mean(), 3),\n    })\n\ng = pd.DataFrame(rows).sort_values("n_movies", ascending=False).reset_index(drop=True)\ng["genre"] = pd.Categorical(g["genre"], categories=list(g["genre"]), ordered=True)\nout_data = table_from_frame(g)\nprint(g.to_string(index=False))\n', 'filename': None}], 'scriptText': 'from Orange.data.pandas_compat import table_to_frame, table_from_frame\nimport pandas as pd\n\ndf = table_to_frame(in_data, include_metas=True)\n\ngcols = [c for c in df.columns if c.startswith("genre_") and c != "genre_count"]\nrows = []\nfor c in gcols:\n    m = df[c] == 1\n    rows.append({\n        "genre": c.replace("genre_", ""),\n        "n_movies": int(m.sum()),\n        "mean_avg_rating": round(df.loc[m, "avg_movie_rating"].mean(), 3),\n    })\n\ng = pd.DataFrame(rows).sort_values("n_movies", ascending=False).reset_index(drop=True)\ng["genre"] = pd.Categorical(g["genre"], categories=list(g["genre"]), ordered=True)\nout_data = table_from_frame(g)\nprint(g.to_string(index=False))\n', 'splitterState': b'\x00\x00\x00\xff\x00\x00\x00\x01\x00\x00\x00\x02\x00\x00\x00\xa5\x00\x00\x00f\x01\xff\xff\xff\xff\x01\x00\x00\x00\x02\x00', 'vimModeEnabled': False, '__version__': 2}</properties>

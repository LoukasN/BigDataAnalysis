		<properties node_id="1" format="literal">{'controlAreaVisible': True, 'currentScriptIndex': 0, 'savedWidgetGeometry': b'\x01\xd9\xd0\xcb\x00\x03\x00\x00\x00\x00\x02\x81\x00\x00\x00\x10\x00\x00\x07\x80\x00\x00\x05\x7f\x00\x00\x02\x82\x00\x00\x00/\x00\x00\x07\x7f\x00\x00\x05~\x00\x00\x00\x00\x00\x00\x00\x00\n\x00\x00\x00\x02\x82\x00\x00\x00/\x00\x00\x07\x7f\x00\x00\x05~', 'scriptLibrary': [{'name': 'Add log10_count + decade', 'script': 'from Orange.data.pandas_compat import table_to_frame, table_from_frame\nimport numpy as np\nimport pandas as pd\n\ndf = table_to_frame(in_data, include_metas=True)\n\n\ndecade = (df["release_year"] // 10 * 10).astype(int)\nlabels = np.where(decade &lt; 1950, "&lt;1950", decade.astype(str) + "s")\norder = ["&lt;1950"] + [f"{d}s" for d in range(1950, 2020, 10)]\ndf["decade"] = pd.Categorical(labels, categories=order, ordered=True)\n\nout_data = table_from_frame(df)\n', 'filename': None}], 'scriptText': 'from Orange.data.pandas_compat import table_to_frame, table_from_frame\nimport numpy as np\nimport pandas as pd\n\ndf = table_to_frame(in_data, include_metas=True)\n\n\ndecade = (df["release_year"] // 10 * 10).astype(int)\nlabels = np.where(decade &lt; 1950, "&lt;1950", decade.astype(str) + "s")\norder = ["&lt;1950"] + [f"{d}s" for d in range(1950, 2020, 10)]\ndf["decade"] = pd.Categorical(labels, categories=order, ordered=True)\n\nout_data = table_from_frame(df)\n', 'splitterState': b'\x00\x00\x00\xff\x00\x00\x00\x01\x00\x00\x00\x02\x00\x00\x00\xa5\x00\x00\x00f\x01\xff\xff\xff\xff\x01\x00\x00\x00\x02\x00', 'vimModeEnabled': False, '__version__': 2}</properties>

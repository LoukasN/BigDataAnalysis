		<properties node_id="37" format="literal">{'auto_commit': True, 'color_by_class': True, 'controlAreaVisible': True, 'savedWidgetGeometry': b'\x01\xd9\xd0\xcb\x00\x03\x00\x00\xff\xff\xff\xd2\x00\x00\x00\x0f\x00\x00\x07a\x00\x00\x04&amp;\xff\xff\xff\xda\x00\x00\x00.\x00\x00\x07Y\x00\x00\x04\x1e\x00\x00\x00\x00\x00\x00\x00\x00\x07\x80\xff\xff\xff\xda\x00\x00\x00.\x00\x00\x07Y\x00\x00\x04\x1e', 'select_rows': True, 'show_attribute_labels': True, 'show_distributions': False, 'stored_selection': {'rows': [], 'columns': []}, 'stored_sort': [('movieId', 1), ('avg_movie_rating', 1), ('rating_count', 1), ('rating_std', 1), ('release_year', 1), ('genre_count', 1)], '__version__': 1}</properties>
		<properties node_id="38" format="literal">{'controlAreaVisible': True, 'currentScriptIndex': 0, 'savedWidgetGeometry': b'\x01\xd9\xd0\xcb\x00\x03\x00\x00\x00\x00\x01I\x00\x00\x00=\x00\x00\x06\xb6\x00\x00\x03\xb5\x00\x00\x01J\x00\x00\x00\\\x00\x00\x06\xb5\x00\x00\x03\xb4\x00\x00\x00\x00\x00\x00\x00\x00\x07\x80\x00\x00\x01J\x00\x00\x00\\\x00\x00\x06\xb5\x00\x00\x03\xb4', 'scriptLibrary': [{'name': 'Table from numpy', 'script': 'from Orange.data.pandas_compat import table_to_frame\n\ndf = table_to_frame(in_data, include_metas=True)\n\n# A (userId, movieId) pair appearing more than once = same user rated same movie twice\ndupe_mask = df.duplicated(subset=[\'userId\', \'movieId\'], keep=False)\ndupes = df[dupe_mask]\n\nprint(f"Total rows: {len(df)}")\nprint(f"Duplicate (user, movie) rows: {len(dupes)}")\nprint(f"Affected (user, movie) pairs: {dupes.groupby([\'userId\',\'movieId\']).ngroups}")\n\nif len(dupes) &gt; 0:\n    print("\\nSample:")\n    cols = [c for c in [\'userId\',\'movieId\',\'rating\'] if c in df.columns]\n    print(dupes.sort_values([\'userId\',\'movieId\'])[cols].head(20).to_string(index=False))', 'filename': None}], 'scriptText': 'from Orange.data.pandas_compat import table_to_frame\n\ndf = table_to_frame(in_data, include_metas=True)\n\n# A (userId, movieId) pair appearing more than once = same user rated same movie twice\ndupe_mask = df.duplicated(subset=[\'userId\', \'movieId\'], keep=False)\ndupes = df[dupe_mask]\n\nprint(f"Total rows: {len(df)}")\nprint(f"Duplicate (user, movie) rows: {len(dupes)}")\nprint(f"Affected (user, movie) pairs: {dupes.groupby([\'userId\',\'movieId\']).ngroups}")\n\nif len(dupes) &gt; 0:\n    print("\\nSample:")\n    cols = [c for c in [\'userId\',\'movieId\',\'rating\'] if c in df.columns]\n    print(dupes.sort_values([\'userId\',\'movieId\'])[cols].head(20).to_string(index=False))', 'splitterState': b'\x00\x00\x00\xff\x00\x00\x00\x01\x00\x00\x00\x02\x00\x00\x00\xa5\x00\x00\x00f\x01\xff\xff\xff\xff\x01\x00\x00\x00\x02\x00', 'vimModeEnabled': False, '__version__': 2}</properties>

		<properties node_id="5" format="literal">{'_session_items': [], '_session_items_v2': [({'type': 'AbsPath', 'path': 'C:/Users/katec/Downloads/BigData/MovieLens20M/tag.csv'}, {'encoding': 'utf-8', 'delimiter': ',', 'quotechar': '"', 'doublequote': True, 'skipinitialspace': True, 'quoting': 0, 'columntypes': [{'start': 0, 'stop': 4, 'value': 'Auto'}], 'rowspec': [{'start': 0, 'stop': 1, 'value': 'Header'}], 'decimal_separator': '.', 'group_separator': ''})], 'compatibility_mode': False, 'controlAreaVisible': True, 'dialog_state': {'directory': 'C:/Users/katec/Downloads/BigData/MovieLens20M', 'filter': 'Text - comma separated (*.csv, *)'}, 'savedWidgetGeometry': b'\x01\xd9\xd0\xcb\x00\x03\x00\x00\x00\x00\x04\xa1\x00\x00\x01\x80\x00\x00\x05\xc1\x00\x00\x02\xdd\x00\x00\x04\xa2\x00\x00\x01\x9f\x00\x00\x05\xc0\x00\x00\x02\xdc\x00\x00\x00\x00\x00\x00\x00\x00\x07\x80\x00\x00\x04\xa2\x00\x00\x01\x9f\x00\x00\x05\xc0\x00\x00\x02\xdc', '__version__': 3}</properties>
		<properties node_id="6" format="literal">{'controlAreaVisible': True, 'currentScriptIndex': 0, 'savedWidgetGeometry': b'\x01\xd9\xd0\xcb\x00\x03\x00\x00\x00\x00\x00\xc8\x00\x00\x00y\x00\x00\x065\x00\x00\x03\xf1\x00\x00\x00\xc9\x00\x00\x00\x98\x00\x00\x064\x00\x00\x03\xf0\x00\x00\x00\x00\x00\x00\x00\x00\x07\x80\x00\x00\x00\xc9\x00\x00\x00\x98\x00\x00\x064\x00\x00\x03\xf0', 'scriptLibrary': [{'name': 'Table from numpy', 'script': 'from Orange.data.pandas_compat import table_to_frame, table_from_frame\n\ndf = table_to_frame(in_data, include_metas=True)\n\ndef merge_genres(genres_series):\n    all_genres = set()\n    for g in genres_series:\n        for genre in g.split(\'|\'):\n            all_genres.add(genre.strip())\n    return \'|\'.join(sorted(all_genres))\n\n\nid_mapping = {}\ndupes = df[df.duplicated(subset=[\'title\'], keep=False)]\nfor title, group in dupes.groupby(\'title\'):\n    min_id = group[\'movieId\'].min()\n    for old_id in group[\'movieId\']:\n        if old_id != min_id:\n            id_mapping[old_id] = min_id\n\nprint(f"ID mappings: {id_mapping}")\n\ndf_clean = df.groupby(\'title\', as_index=False).agg(\n    movieId=(\'movieId\', \'min\'),\n    genres=(\'genres\', merge_genres)\n)\n\nprint(f"Πριν: {len(df)} γραμμές")\nprint(f"Μετά: {len(df_clean)} γραμμές")\n\nout_data = table_from_frame(df_clean)', 'filename': None}], 'scriptText': 'from Orange.data.pandas_compat import table_to_frame, table_from_frame\n\ndf = table_to_frame(in_data, include_metas=True)\n\ndef merge_genres(genres_series):\n    all_genres = set()\n    for g in genres_series:\n        for genre in g.split(\'|\'):\n            all_genres.add(genre.strip())\n    return \'|\'.join(sorted(all_genres))\n\n\nid_mapping = {}\ndupes = df[df.duplicated(subset=[\'title\'], keep=False)]\nfor title, group in dupes.groupby(\'title\'):\n    min_id = group[\'movieId\'].min()\n    for old_id in group[\'movieId\']:\n        if old_id != min_id:\n            id_mapping[old_id] = min_id\n\nprint(f"ID mappings: {id_mapping}")\n\ndf_clean = df.groupby(\'title\', as_index=False).agg(\n    movieId=(\'movieId\', \'min\'),\n    genres=(\'genres\', merge_genres)\n)\n\nprint(f"Πριν: {len(df)} γραμμές")\nprint(f"Μετά: {len(df_clean)} γραμμές")\n\nout_data = table_from_frame(df_clean)', 'splitterState': b'\x00\x00\x00\xff\x00\x00\x00\x01\x00\x00\x00\x02\x00\x00\x00\xa5\x00\x00\x00f\x01\xff\xff\xff\xff\x01\x00\x00\x00\x02\x00', 'vimModeEnabled': False, '__version__': 2}</properties>

		<properties node_id="1" format="literal">{'controlAreaVisible': True, 'currentScriptIndex': 0, 'savedWidgetGeometry': b'\x01\xd9\xd0\xcb\x00\x03\x00\x00\x00\x00\x01\xa8\x00\x00\x00:\x00\x00\x07\x15\x00\x00\x03\xb2\x00\x00\x01\xa9\x00\x00\x00Y\x00\x00\x07\x14\x00\x00\x03\xb1\x00\x00\x00\x00\x00\x00\x00\x00\x07\x80\x00\x00\x01\xa9\x00\x00\x00Y\x00\x00\x07\x14\x00\x00\x03\xb1', 'scriptLibrary': [{'name': 'Table from numpy', 'script': 'from Orange.data.pandas_compat import table_to_frame\n\ndf = table_to_frame(in_data, include_metas=True)\n\nprint(f"=== Duplicate Analysis ===")\nprint(f"Συνολικές γραμμές: {len(df)}")\nprint(f"Columns: {df.columns.tolist()}")\n\nfor col in df.columns:\n    n_unique = df[col].nunique()\n    n_dupes = len(df) - n_unique\n    dupe_pct = (n_dupes / len(df)) * 100\n    print(f"\\n[{col}]")\n    print(f"  Unique values: {n_unique}")\n    print(f"  Duplicates: {n_dupes} ({dupe_pct:.2f}%)")\n    if n_dupes &gt; 0 and n_dupes &lt; 100:\n        print(f"  Duplicate values:")\n        dupe_vals = df[col][df[col].duplicated(keep=False)].unique()\n        for v in dupe_vals:\n            print(f"    {v}")\n\nprint(f"\\n=== Full row duplicates ===")\nfull_dupes = df.duplicated(keep=False).sum()\nprint(f"Identical rows: {full_dupes}")\nif full_dupes &gt; 0 and full_dupes &lt; 100:\n    print(df[df.duplicated(keep=False)].to_string())', 'filename': None}], 'scriptText': 'from Orange.data.pandas_compat import table_to_frame\n\ndf = table_to_frame(in_data, include_metas=True)\n\nprint(f"=== Duplicate Analysis ===")\nprint(f"Συνολικές γραμμές: {len(df)}")\nprint(f"Columns: {df.columns.tolist()}")\n\nfor col in df.columns:\n    n_unique = df[col].nunique()\n    n_dupes = len(df) - n_unique\n    dupe_pct = (n_dupes / len(df)) * 100\n    print(f"\\n[{col}]")\n    print(f"  Unique values: {n_unique}")\n    print(f"  Duplicates: {n_dupes} ({dupe_pct:.2f}%)")\n    if n_dupes &gt; 0 and n_dupes &lt; 100:\n        print(f"  Duplicate values:")\n        dupe_vals = df[col][df[col].duplicated(keep=False)].unique()\n        for v in dupe_vals:\n            print(f"    {v}")\n\nprint(f"\\n=== Full row duplicates ===")\nfull_dupes = df.duplicated(keep=False).sum()\nprint(f"Identical rows: {full_dupes}")\nif full_dupes &gt; 0 and full_dupes &lt; 100:\n    print(df[df.duplicated(keep=False)].to_string())', 'splitterState': b'\x00\x00\x00\xff\x00\x00\x00\x01\x00\x00\x00\x02\x00\x00\x00\xa5\x00\x00\x00f\x01\xff\xff\xff\xff\x01\x00\x00\x00\x02\x00', 'vimModeEnabled': False, '__version__': 2}</properties>

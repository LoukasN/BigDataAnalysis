		<properties node_id="26" format="literal">{'controlAreaVisible': True, 'currentScriptIndex': 0, 'savedWidgetGeometry': b'\x01\xd9\xd0\xcb\x00\x03\x00\x00\x00\x00\x02/\x00\x00\x00\xb9\x00\x00\x05P\x00\x00\x030\x00\x00\x020\x00\x00\x00\xd8\x00\x00\x05O\x00\x00\x03/\x00\x00\x00\x00\x00\x00\x00\x00\x07\x80\x00\x00\x020\x00\x00\x00\xd8\x00\x00\x05O\x00\x00\x03/', 'scriptLibrary': [{'name': 'Table from numpy', 'script': '# Diagnostic only — list unique genre tokens. Delete after reading.\nimport Orange\n\ngenres_var = in_data.domain["genres"]\ncol_idx = in_data.domain.index(genres_var)\n\ntokens = set()\nfor row in in_data:\n    val = str(row[genres_var])\n    if val and val != "?":            # skip Orange\'s missing marker\n        for g in val.split("|"):\n            tokens.add(g.strip())\n\nprint("Unique genre tokens:", len(tokens))\nfor t in sorted(tokens):\n    print(" -", t)\n\nout_data = in_data  # pass-through, changes nothing', 'filename': None}], 'scriptText': '# Diagnostic only — list unique genre tokens. Delete after reading.\nimport Orange\n\ngenres_var = in_data.domain["genres"]\ncol_idx = in_data.domain.index(genres_var)\n\ntokens = set()\nfor row in in_data:\n    val = str(row[genres_var])\n    if val and val != "?":            # skip Orange\'s missing marker\n        for g in val.split("|"):\n            tokens.add(g.strip())\n\nprint("Unique genre tokens:", len(tokens))\nfor t in sorted(tokens):\n    print(" -", t)\n\nout_data = in_data  # pass-through, changes nothing', 'splitterState': b'\x00\x00\x00\xff\x00\x00\x00\x01\x00\x00\x00\x02\x00\x00\x00\x9f\x00\x00\x00`\x01\xff\xff\xff\xff\x01\x00\x00\x00\x02\x00', 'vimModeEnabled': False, '__version__': 2}</properties>
		<properties node_id="27" format="literal">{'controlAreaVisible': True, 'currentScriptIndex': 0, 'savedWidgetGeometry': b'\x01\xd9\xd0\xcb\x00\x03\x00\x00\x00\x00\x03\xb3\x00\x00\x00\xcc\x00\x00\x06\xd4\x00\x00\x03C\x00\x00\x03\xb4\x00\x00\x00\xeb\x00\x00\x06\xd3\x00\x00\x03B\x00\x00\x00\x00\x00\x00\x00\x00\x07\x80\x00\x00\x03\xb4\x00\x00\x00\xeb\x00\x00\x06\xd3\x00\x00\x03B', 'scriptLibrary': [{'name': 'Table from numpy', 'script': '# 4d — One-hot encode the |-delimited genres column.\n# Dynamic token derivation, no hardcoded list. Placeholder excluded.\n# NOTE: `genres` is ALREADY a meta — do not re-add it.\nimport numpy as np\nimport Orange\nfrom Orange.data import Domain, ContinuousVariable\n\nPLACEHOLDER = "(no genres listed)"   # TODO: confirm token if dataset ever changes\ngenres_var = in_data.domain["genres"]\n\n# 1. Collect genre tokens dynamically (sorted for stable column order)\ntokens = set()\nfor row in in_data:\n    val = str(row[genres_var])\n    if val and val != "?":\n        for g in val.split("|"):\n            g = g.strip()\n            if g and g != PLACEHOLDER:\n                tokens.add(g)\ngenre_list = sorted(tokens)\n\n# 2. Build one binary column per genre\nnew_vars = [ContinuousVariable("genre_" + g) for g in genre_list]\nonehot = np.zeros((len(in_data), len(genre_list)), dtype=float)\nfor i, row in enumerate(in_data):\n    val = str(row[genres_var])\n    if val and val != "?":\n        present = {g.strip() for g in val.split("|")}\n        for j, g in enumerate(genre_list):\n            if g in present:\n                onehot[i, j] = 1.0\n\n# 3. Append genre columns to attributes; leave class &amp; metas untouched\nold = in_data.domain\nnew_domain = Domain(list(old.attributes) + new_vars, old.class_vars, old.metas)\n\nout_data = in_data.transform(new_domain)\nout_data.X[:, -len(genre_list):] = onehot   # fill the appended columns\n\nprint("Genres one-hot encoded:", len(genre_list), "columns")\nprint("Columns:", ", ".join("genre_" + g for g in genre_list))', 'filename': None}], 'scriptText': '# 4d — One-hot encode the |-delimited genres column.\n# Dynamic token derivation, no hardcoded list. Placeholder excluded.\n# NOTE: `genres` is ALREADY a meta — do not re-add it.\nimport numpy as np\nimport Orange\nfrom Orange.data import Domain, ContinuousVariable\n\nPLACEHOLDER = "(no genres listed)"   # TODO: confirm token if dataset ever changes\ngenres_var = in_data.domain["genres"]\n\n# 1. Collect genre tokens dynamically (sorted for stable column order)\ntokens = set()\nfor row in in_data:\n    val = str(row[genres_var])\n    if val and val != "?":\n        for g in val.split("|"):\n            g = g.strip()\n            if g and g != PLACEHOLDER:\n                tokens.add(g)\ngenre_list = sorted(tokens)\n\n# 2. Build one binary column per genre\nnew_vars = [ContinuousVariable("genre_" + g) for g in genre_list]\nonehot = np.zeros((len(in_data), len(genre_list)), dtype=float)\nfor i, row in enumerate(in_data):\n    val = str(row[genres_var])\n    if val and val != "?":\n        present = {g.strip() for g in val.split("|")}\n        for j, g in enumerate(genre_list):\n            if g in present:\n                onehot[i, j] = 1.0\n\n# 3. Append genre columns to attributes; leave class &amp; metas untouched\nold = in_data.domain\nnew_domain = Domain(list(old.attributes) + new_vars, old.class_vars, old.metas)\n\nout_data = in_data.transform(new_domain)\nout_data.X[:, -len(genre_list):] = onehot   # fill the appended columns\n\nprint("Genres one-hot encoded:", len(genre_list), "columns")\nprint("Columns:", ", ".join("genre_" + g for g in genre_list))', 'splitterState': b'\x00\x00\x00\xff\x00\x00\x00\x01\x00\x00\x00\x02\x00\x00\x00\x9f\x00\x00\x00`\x01\xff\xff\xff\xff\x01\x00\x00\x00\x02\x00', 'vimModeEnabled': False, '__version__': 2}</properties>

		<properties node_id="18" format="literal">{'controlAreaVisible': True, 'currentScriptIndex': 0, 'savedWidgetGeometry': b'\x01\xd9\xd0\xcb\x00\x03\x00\x00\x00\x00\x00A\x00\x00\x00\xc2\x00\x00\x04\xdc\x00\x00\x04\x11\x00\x00\x00B\x00\x00\x00\xe1\x00\x00\x04\xdb\x00\x00\x04\x10\x00\x00\x00\x00\x00\x00\x00\x00\x07\x80\x00\x00\x00B\x00\x00\x00\xe1\x00\x00\x04\xdb\x00\x00\x04\x10', 'scriptLibrary': [{'name': 'Table from numpy', 'script': 'from Orange.data.pandas_compat import table_to_frame, table_from_frame\nimport re\n\ndf = table_to_frame(in_data, include_metas=True)\n\n# --- Collapse 20M rows -&gt; one row per movie (no native Orange equivalent) ---\n# Aggregates computed on FULL data, before any filter (so count/std are unbiased)\nagg = df.groupby(\'movieId\').agg(\n    avg_movie_rating=(\'rating\', \'mean\'),\n    rating_count=(\'rating\', \'count\'),\n    rating_std=(\'rating\', \'std\'),\n    title=(\'title\', \'first\'),\n    genres=(\'genres\', \'first\'),\n).reset_index()\n\n# --- release_year: last parenthesized 4-digit group in title ---\ndef extract_year(title):\n    matches = re.findall(r\'\\((\\d{4})\\)\', str(title))\n    return int(matches[-1]) if matches else None\n\nagg[\'release_year\'] = agg[\'title\'].apply(extract_year)\n\n# --- genre_count: 0 for no-genres, else count of \'|\'-separated genres ---\ndef count_genres(g):\n    return 0 if g == \'(no genres listed)\' else len(g.split(\'|\'))\n\nagg[\'genre_count\'] = agg[\'genres\'].apply(count_genres)\n\n# --- Diagnostics (for report; counts unfiltered here) ---\nprint(f"Movies (unfiltered): {len(agg)}")\nprint(f"release_year missing: {agg[\'release_year\'].isna().sum()}")\nprint(f"rating_std missing: {agg[\'rating_std\'].isna().sum()}")\nprint(f"no-genre movies: {(agg[\'genre_count\'] == 0).sum()}")\n\nout_data = table_from_frame(agg)', 'filename': None}], 'scriptText': 'from Orange.data.pandas_compat import table_to_frame, table_from_frame\nimport re\n\ndf = table_to_frame(in_data, include_metas=True)\n\n# --- Collapse 20M rows -&gt; one row per movie (no native Orange equivalent) ---\n# Aggregates computed on FULL data, before any filter (so count/std are unbiased)\nagg = df.groupby(\'movieId\').agg(\n    avg_movie_rating=(\'rating\', \'mean\'),\n    rating_count=(\'rating\', \'count\'),\n    rating_std=(\'rating\', \'std\'),\n    title=(\'title\', \'first\'),\n    genres=(\'genres\', \'first\'),\n).reset_index()\n\n# --- release_year: last parenthesized 4-digit group in title ---\ndef extract_year(title):\n    matches = re.findall(r\'\\((\\d{4})\\)\', str(title))\n    return int(matches[-1]) if matches else None\n\nagg[\'release_year\'] = agg[\'title\'].apply(extract_year)\n\n# --- genre_count: 0 for no-genres, else count of \'|\'-separated genres ---\ndef count_genres(g):\n    return 0 if g == \'(no genres listed)\' else len(g.split(\'|\'))\n\nagg[\'genre_count\'] = agg[\'genres\'].apply(count_genres)\n\n# --- Diagnostics (for report; counts unfiltered here) ---\nprint(f"Movies (unfiltered): {len(agg)}")\nprint(f"release_year missing: {agg[\'release_year\'].isna().sum()}")\nprint(f"rating_std missing: {agg[\'rating_std\'].isna().sum()}")\nprint(f"no-genre movies: {(agg[\'genre_count\'] == 0).sum()}")\n\nout_data = table_from_frame(agg)', 'splitterState': b'\x00\x00\x00\xff\x00\x00\x00\x01\x00\x00\x00\x02\x00\x00\x00\x9f\x00\x00\x00`\x01\xff\xff\xff\xff\x01\x00\x00\x00\x02\x00', 'vimModeEnabled': False, '__version__': 2}</properties>
